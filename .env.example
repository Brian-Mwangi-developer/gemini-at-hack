# ── Google Gemini (required) ──────────────────────────────
# Get your key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ── OpenAI (optional — required to use GPT models) ────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Anthropic Claude (optional — required to use Claude models) ──
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Exa Search (required for web search) ─────────────────
# Get your key at https://exa.ai
EXA_API_KEY=your-exa-api-key-here

# ── LangSmith Tracing (optional) ─────────────────────────
# Get your key at https://smith.langchain.com
LANGSMITH_KEY=your-langsmith-key-here

# ── PostgreSQL (provided by Docker Compose) ──────────────
DATABASE_URL="postgresql://gemigraph:gemigraph@localhost:5432/gemigraph"
LANGCHAIN_PROJECT=gemigraph-research-agent

# ── Africa's Talking SMS (optional) ──────────────────────
# Get credentials at https://account.africastalking.com
AT_KEY=your-africastalking-api-key-here
AT_NAME=your-africastalking-username-here
AT_SENDER_NAME=your-sender-id-here

# ── Public URL (optional — for SMS links) ────────────────
# Set this when using a tunnel (ngrok/cloudflared) so SMS
# recipients get a public URL instead of localhost.
# NEXT_PUBLIC_APP_URL=https://your-tunnel.ngrok-free.app
